# IIVO Glass — optional STT configuration
# Glass prefers the running IIVO server (/api/transcribe-audio) when IIVO_GLASS_STT_ENDPOINT=server (default).

# Sentry crash telemetry (main + renderer; baked into packaged builds at compile time)
SENTRY_DSN=

# ElevenLabs TTS — IIVO voice (Matilda). See src/shared/iivoVoiceSpec.ts for full spec.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX
# ELEVENLABS_MODEL=eleven_turbo_v2_5

# Anthropic — Glass direct ask + Council + Coder (stored in macOS Keychain via safeStorage)
# On first launch, Glass migrates ANTHROPIC_API_KEY from .env into encrypted storage.
ANTHROPIC_API_KEY=
# IIVO_GLASS_ANTHROPIC_MODEL=claude-sonnet-4-6
# IIVO_GLASS_ANTHROPIC_DIAGNOSTIC_MODEL=claude-opus-4-8

# IIVO server URL — landing page, updates, STT endpoint only (inference is local)
IIVO_API_URL=http://localhost:3001
IIVO_WEB_URL=http://localhost:5173

# Must match server GLASS_API_SECRET for legacy server routes (updates/landing only).
IIVO_GLASS_API_SECRET=

# STT — direct Glass (recommended for a separate Glass-only OpenAI key)
IIVO_GLASS_STT_ENABLED=true
IIVO_GLASS_STT_PROVIDER=openai
IIVO_GLASS_STT_ENDPOINT=direct
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Paste your Glass-only key here (loaded by Glass main process only — never renderer)
# Set in repo root .env as IIVO_GLASS_OPENAI_API_KEY=
IIVO_GLASS_OPENAI_API_KEY=

# Server-side Glass direct AI models — retired; Glass uses local Anthropic key now.
# IIVO_GLASS_OPENAI_MODEL=gpt-5.5
# IIVO_GLASS_VISION_MODEL=gpt-5.5

# IIVO_GLASS_STT_ENDPOINT=server

# Legacy fallback if IIVO_GLASS_OPENAI_API_KEY is unset (not recommended for separate billing)
# OPENAI_API_KEY=

# Optional cost controls
# IIVO_GLASS_STT_AUTO_STOP=true
# IIVO_GLASS_STT_AUTO_STOP_MINUTES=30

# Full-screen intelligence overlay (click-through; on by default)
# IIVO_GLASS_OVERLAY_ENABLED=false

# Overlay visual mode: passive | insights | hidden
# IIVO_GLASS_OVERLAY_MODE=passive

# Layout preset: compact_dock | floating_dock | side_panel | full_glass_overlay | focus_mode
# IIVO_GLASS_LAYOUT_PRESET=compact_dock

# --- Glass Companion — optional OmniParser sidecar (see GLASS_COMPANION_OMNIPARSER.md) ---
# Companion works without this. After install (Panel → Installations), enables automatically.
# One-time install: Panel → Installations → Install OmniParser (or ./omniparser-sidecar/install-models.sh)
# IIVO_COMPANION_OMNI_PARSER=0   # force off even when weights installed
# IIVO_OMNIPARSER_SPAWN=0        # disable auto-start when Companion turns on

# --- macOS signed release (npm run package:mac:signed) — do NOT commit real values ---
# APPLE_ID=incawgnito.x@gmail.com
# APPLE_TEAM_ID=3WRBTRX524
# APPLE_ID_PASSWORD=xxxx-xxxx-xxxx-xxxx
