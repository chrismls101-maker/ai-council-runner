# IIVO Glass — optional STT configuration
# Glass prefers the running IIVO server (/api/transcribe-audio) when IIVO_GLASS_STT_ENDPOINT=server (default).

# IIVO server URL (Glass reads IIVO_API_URL from environment when launched)
IIVO_API_URL=http://localhost:3001
IIVO_WEB_URL=http://localhost:5173

# STT — direct Glass (recommended for a separate Glass-only OpenAI key)
IIVO_GLASS_STT_ENABLED=true
IIVO_GLASS_STT_PROVIDER=openai
IIVO_GLASS_STT_ENDPOINT=direct
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Paste your Glass-only key here (loaded by Glass main process only — never renderer)
# Set in repo root .env as IIVO_GLASS_OPENAI_API_KEY=
IIVO_GLASS_OPENAI_API_KEY=

# Server-first alternative (uses root OPENAI_API_KEY via npm run dev)
# IIVO_GLASS_STT_ENDPOINT=server

# Legacy fallback if IIVO_GLASS_OPENAI_API_KEY is unset (not recommended for separate billing)
# OPENAI_API_KEY=

# Optional cost controls
# IIVO_GLASS_STT_AUTO_STOP=true
# IIVO_GLASS_STT_AUTO_STOP_MINUTES=30

# Full-screen intelligence overlay (click-through; on by default)
# IIVO_GLASS_OVERLAY_ENABLED=false

# Overlay visual mode: passive | insights | hidden
# IIVO_GLASS_OVERLAY_MODE=passive

# Layout preset: compact_dock | floating_dock | side_panel | full_glass_overlay | focus_mode
# IIVO_GLASS_LAYOUT_PRESET=compact_dock
