# IIVO Glass — optional STT configuration
# Glass prefers the running IIVO server (/api/transcribe-audio) when IIVO_GLASS_STT_ENDPOINT=server (default).

# IIVO server URL (Glass reads IIVO_API_URL from environment when launched)
IIVO_API_URL=http://localhost:3001
IIVO_WEB_URL=http://localhost:5173

# STT — server-first (recommended when npm run dev is running with OPENAI_API_KEY in root .env)
IIVO_GLASS_STT_ENABLED=true
IIVO_GLASS_STT_PROVIDER=openai
IIVO_GLASS_STT_ENDPOINT=server
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Direct Glass OpenAI fallback (main process only — never exposed to renderer)
# OPENAI_API_KEY=sk-...
# IIVO_GLASS_STT_ENDPOINT=direct

# Optional cost controls
# IIVO_GLASS_STT_AUTO_STOP=true
# IIVO_GLASS_STT_AUTO_STOP_MINUTES=30
