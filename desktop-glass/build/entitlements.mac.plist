<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Minimal entitlements required for a hardened-runtime Electron app. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!--
    NOTE: macOS Screen Recording is granted by the user at runtime via
    System Settings -> Privacy & Security -> Screen Recording (TCC), not via an
    entitlement. Do not add broad sandbox/device entitlements unless needed.
  -->
</dict>
</plist>
