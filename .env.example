OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# IIVO Glass STT (server endpoint uses OPENAI_API_KEY via POST /api/transcribe-audio)
IIVO_GLASS_STT_ENABLED=true
IIVO_GLASS_STT_PROVIDER=openai
IIVO_GLASS_STT_ENDPOINT=server
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Glass-only OpenAI key for direct STT (main process only — separate from Council key)
# IIVO_GLASS_OPENAI_API_KEY=
# IIVO_GLASS_STT_ENDPOINT=direct

# IIVO Glass direct AI models (server-side /api/glass/ask)
# Probed at runtime; falls back to gpt-4o if unavailable.
# IIVO_GLASS_OPENAI_MODEL=gpt-5.5
# IIVO_GLASS_VISION_MODEL=gpt-5.5
# IIVO_GLASS_DIAGNOSTIC_MODEL=
# IIVO_GLASS_SEMANTIC_MODEL=

# Image vision (IIVO Lens screenshot analysis)
IMAGE_VISION_ENABLED=false
IMAGE_VISION_PROVIDER=openai
IMAGE_VISION_MODEL=

# Optional future URL screenshot capture (not used for vision analysis)
# SCREENSHOT_CAPTURE_PROVIDER=screenshotone
# SCREENSHOTONE_API_KEY=

# ─── GLASS_API_SECRET — Bearer token for all protected /api/glass/* routes ────
#
# WHAT IT IS:
#   A shared secret between IIVO Glass (Electron app) and this server. Glass
#   sends it as "Authorization: Bearer <secret>" on every API call. The server
#   rejects requests that don't match. Without this set, all Glass endpoints are
#   open to anyone who can reach the server URL.
#
# HOW TO GENERATE:
#   openssl rand -hex 32
#
# HOW TO ROTATE (zero-downtime):
#   1. Generate a new secret: openssl rand -hex 32
#   2. Set GLASS_API_SECRET=<new> in Railway environment variables (do NOT redeploy yet)
#   3. Build and release the next IIVO Glass DMG with IIVO_GLASS_API_SECRET=<new> in
#      desktop-glass/.env before packaging.
#   4. Publish the new DMG to GitHub Releases.
#   5. Redeploy the Railway service — the new secret is now active.
#   6. Old Glass clients will get 401 errors and must update. Notify users before rotating.
#
# REQUIRED in production. Leave blank for local development (auth is skipped when unset).
GLASS_API_SECRET=

# Set to https://iivo.ai in production. Leaving blank opens CORS to all origins.
# Required in production to prevent unauthorized cross-origin API access.
ALLOWED_ORIGIN=

# Optional password for the public Glass landing page at /. Unset = no gate.
# LANDING_PASSWORD=

# NODE_ENV is set automatically by Railway from the build environment.
# Do not set this manually unless you know what you're doing.
# NODE_ENV=production

# ─── Auth (better-auth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# ─── Database (PostgreSQL on Railway) ─────────────────────────────────────────
# Copy from Railway → your service → Variables → DATABASE_URL after adding Postgres plugin
DATABASE_URL=

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# App: https://github.com/settings/applications/3659015
# Callback URL: https://iivo.ai/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Callback URL: https://iivo.ai/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (Resend) — for magic link login emails ─────────────────────────────
# Sign up free at: https://resend.com — 3,000 emails/month free
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@iivo.ai
