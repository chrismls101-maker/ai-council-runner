OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# IIVO Glass STT (server endpoint uses this key via POST /api/transcribe-audio)
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Image vision (IIVO Lens screenshot analysis)
IMAGE_VISION_ENABLED=false
IMAGE_VISION_PROVIDER=openai
IMAGE_VISION_MODEL=

