OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# IIVO Glass STT (server endpoint uses OPENAI_API_KEY via POST /api/transcribe-audio)
IIVO_GLASS_STT_ENABLED=true
IIVO_GLASS_STT_PROVIDER=openai
IIVO_GLASS_STT_ENDPOINT=server
IIVO_GLASS_STT_MODEL=gpt-4o-mini-transcribe

# Glass-only OpenAI key for direct STT (main process only — separate from Council key)
# IIVO_GLASS_OPENAI_API_KEY=
# IIVO_GLASS_STT_ENDPOINT=direct

# IIVO Glass direct AI models (server-side /api/glass/ask)
# Probed at runtime; falls back to gpt-4o if unavailable.
# IIVO_GLASS_OPENAI_MODEL=gpt-5.5
# IIVO_GLASS_VISION_MODEL=gpt-5.5
# IIVO_GLASS_DIAGNOSTIC_MODEL=
# IIVO_GLASS_SEMANTIC_MODEL=

# Image vision (IIVO Lens screenshot analysis)
IMAGE_VISION_ENABLED=false
IMAGE_VISION_PROVIDER=openai
IMAGE_VISION_MODEL=

# Optional future URL screenshot capture (not used for vision analysis)
# SCREENSHOT_CAPTURE_PROVIDER=screenshotone
# SCREENSHOTONE_API_KEY=

# Bearer token for /api/* when deployed publicly (Glass sends as IIVO_GLASS_API_SECRET)
GLASS_API_SECRET=

# Set to https://iivo.ai in production.
ALLOWED_ORIGIN=

# Optional password for the public Glass landing page at /. Unset = no gate.
# LANDING_PASSWORD=
