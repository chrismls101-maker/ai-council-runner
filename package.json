{
  "name": "ai-council-runner",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "prototype:glass-logo": "vite --open /prototypes/glass-logo/index.html",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "NODE_ENV=production node dist/server/index.js",
    "deploy:server": "node scripts/deploy-server.mjs",
    "glass-browse:stats-snapshot": "node scripts/glass-browse-stats-snapshot.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test:followup": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/followUpContext.test.ts && node --experimental-strip-types tests/server/followUpIntegration.test.ts",
    "test:preset": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/presetDefault.test.ts",
    "test:context-guard": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/globalContextGuard.test.ts",
    "test:routing": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/routingHeuristics.test.ts",
    "test:response-contracts": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/responseContracts.test.ts",
    "test:execution-mode": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/executionMode.test.ts",
    "test:benchmark": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/benchmarkScoring.test.ts",
    "qa:install": "playwright install chromium",
    "qa:visual": "playwright test --headed --project=chromium",
    "qa:visual:watch": "QA_VISUAL_WATCH=1 playwright test --headed --project=chromium",
    "qa:visual:step": "QA_VISUAL_STEP=1 playwright test --headed --project=chromium",
    "qa:visual:record": "QA_VISUAL_RECORD=1 playwright test --headed --project=chromium",
    "qa:visual:debug": "playwright test --debug --project=chromium",
    "qa:report": "playwright show-report playwright-report",
    "qa:usage": "playwright test tests/visual/iivo-usage-credits.spec.ts --headed --project=chromium",
    "qa:usage:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-usage-credits.spec.ts --headed --project=chromium",
    "qa:usage:record": "QA_VISUAL_RECORD=1 playwright test tests/visual/iivo-usage-credits.spec.ts --headed --project=chromium",
    "qa:usage:live": "playwright test tests/visual/iivo-usage-credits.spec.ts -g \"Usage live charge flow\" --headed --project=chromium",
    "qa:usage:guard": "playwright test tests/visual/iivo-usage-credits.spec.ts -g \"Usage estimate and guard flow\" --headed --project=chromium",
    "qa:benchmark": "playwright test tests/visual/iivo-benchmark-lab.spec.ts --headed --project=chromium",
    "qa:benchmark:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-benchmark-lab.spec.ts --headed --project=chromium",
    "qa:benchmark:record": "QA_VISUAL_RECORD=1 playwright test tests/visual/iivo-benchmark-lab.spec.ts --headed --project=chromium",
    "qa:readiness": "playwright test tests/visual/iivo-public-readiness.spec.ts --headed --project=chromium",
    "qa:readiness:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-public-readiness.spec.ts --headed --project=chromium",
    "qa:readiness:record": "QA_VISUAL_RECORD=1 playwright test tests/visual/iivo-public-readiness.spec.ts --headed --project=chromium",
    "qa:context": "playwright test tests/visual/iivo-context-bridge.spec.ts --headed --project=chromium",
    "qa:context:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-context-bridge.spec.ts --headed --project=chromium",
    "qa:context:record": "QA_VISUAL_RECORD=1 playwright test tests/visual/iivo-context-bridge.spec.ts --headed --project=chromium",
    "qa:lens": "playwright test tests/visual/iivo-lens-handoff.spec.ts tests/visual/iivo-lens-hardening.spec.ts tests/visual/iivo-lens-screenshot.spec.ts --headed --project=chromium",
    "qa:lens:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-lens-handoff.spec.ts tests/visual/iivo-lens-hardening.spec.ts tests/visual/iivo-lens-screenshot.spec.ts --headed --project=chromium",
    "test:lens": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/contextLens.test.ts && node --experimental-strip-types tests/server/lensDuplicates.test.ts && node --experimental-strip-types tests/server/contextScreenshot.test.ts && node --experimental-strip-types tests/server/screenshotLoader.test.ts && node --experimental-strip-types tests/server/visionAnalyze.test.ts && node --experimental-strip-types tests/server/visionMemoryGuard.test.ts",
    "qa:lens:vision": "VISION_QA_LIVE=1 playwright test tests/visual/iivo-lens-screenshot.spec.ts -g \"lensAsk for screenshot\" --headed --project=chromium",
    "qa:master": "playwright test tests/visual/iivo-master-qa.spec.ts --headed --project=chromium",
    "qa:master:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-master-qa.spec.ts --headed --project=chromium",
    "qa:master:record": "QA_VISUAL_RECORD=1 playwright test tests/visual/iivo-master-qa.spec.ts --headed --project=chromium",
    "qa:master:extension": "playwright test tests/visual/iivo-master-extension.spec.ts --headed --project=chromium",
    "qa:master:vision-live": "VISION_QA_LIVE=1 playwright test tests/visual/iivo-master-vision-live.spec.ts --headed --project=chromium",
    "qa:master:full": "MASTER_QA_FULL=1 playwright test tests/visual/iivo-master-qa.spec.ts --headed --project=chromium",
    "qa:master:benchmark-live": "BENCHMARK_QA_LIVE=1 playwright test tests/visual/iivo-benchmark-lab.spec.ts --headed --project=chromium",
    "qa:daily": "playwright test tests/visual/iivo-daily-driver.spec.ts --headed --project=chromium",
    "qa:daily:watch": "QA_VISUAL_WATCH=1 playwright test tests/visual/iivo-daily-driver.spec.ts --headed --project=chromium",
    "qa:daily:full": "DAILY_QA_FULL=1 playwright test tests/visual/iivo-daily-driver.spec.ts --headed --project=chromium",
    "qa:daily:live": "DAILY_QA_LIVE=1 playwright test tests/visual/iivo-daily-driver.spec.ts --headed --project=chromium",
    "qa:preset": "playwright test tests/visual/iivo-preset-neutral.spec.ts --headed --project=chromium",
    "qa:daily:agent-mind": "playwright test tests/visual/iivo-daily-driver-agent-mind.spec.ts tests/visual/dailyDriverFrictionDetect.test.ts --headed --project=chromium",
    "test:daily-friction": "playwright test tests/visual/dailyDriverFrictionDetect.test.ts tests/visual/dailyDriverRunnerImports.test.ts tests/visual/runWaitHelpersExports.test.ts --project=chromium && node --experimental-strip-types tests/client/safeSessionStorage.test.ts",
    "glass:install": "npm install --prefix glass-app",
    "glass:dev": "npm run dev --prefix glass-app",
    "glass:dev:onboarding": "npm run dev:onboarding --prefix glass-app",
    "glass:dev:activation": "npm run dev:activation --prefix glass-app",
    "glass:build": "npm run build --prefix glass-app",
    "glass:typecheck": "npm run typecheck --prefix glass-app",
    "glass:test": "npm run test --prefix glass-app",
    "glass:stt:live": "node glass-app/scripts/test-openai-stt-live.mjs",
    "glass:qa:manual": "npm run qa:manual --prefix glass-app",
    "glass:qa:voice:manual": "npm run qa:voice:manual --prefix glass-app --",
    "glass:qa:listen:live": "npm run qa:listen:live --prefix glass-app --",
    "glass:qa:listen:preflight": "npm run qa:listen:preflight --prefix glass-app --",
    "glass:qa:listen:endurance:sim": "npm run qa:listen:endurance:sim --prefix glass-app --",
    "glass:qa:translate:manual": "npm run qa:translate:manual --prefix glass-app",
    "glass:qa:manual-report": "npm run glass:qa:manual-report --prefix glass-app",
    "glass:qa:auto": "npm run qa:auto --prefix glass-app",
    "glass:qa:live": "npm run qa:live --prefix glass-app",
    "glass:qa:live-answers": "npm run qa:live-answers --prefix glass-app --",
    "glass:check:models": "npm run check:models --prefix glass-app",
    "glass:qa:copilot:overnight": "npm run qa:copilot:overnight --prefix glass-app",
    "glass:qa:overnight": "npm run qa:overnight --prefix glass-app --",
    "glass:qa:overnight:quick": "npm run qa:overnight:quick --prefix glass-app",
    "glass:e2e:live": "npm run e2e:live --prefix glass-app",
    "glass:qa:smoke": "npm run qa:smoke --prefix glass-app",
    "glass:e2e": "npm run e2e --prefix glass-app",
    "glass:e2e:repeat": "npm run e2e:repeat --prefix glass-app",
    "glass:git:guard": "npm run git:guard --prefix glass-app",
    "glass:git:guard:all": "npm run git:guard:all --prefix glass-app",
    "glass:git:guard:release": "npm run git:guard:release --prefix glass-app",
    "glass:wip:status": "npm run wip:status --prefix glass-app",
    "glass:validate:clean": "npm run validate:clean --prefix glass-app --",
    "glass:e2e:ci": "npm run e2e:ci --prefix glass-app",
    "glass:e2e:display": "npm run e2e:display --prefix glass-app",
    "glass:e2e:headed": "npm run e2e:headed --prefix glass-app",
    "glass:e2e:debug": "npm run e2e:debug --prefix glass-app",
    "test:runId-handoff": "node --experimental-strip-types tests/server/runIdHandoff.test.ts",
    "test:glass-ask": "tsc -p tsconfig.server.json && node --experimental-strip-types tests/server/glassAsk.test.ts && node --experimental-strip-types tests/server/glassModels.test.ts && node --experimental-strip-types tests/server/runIdHandoff.test.ts && node --experimental-strip-types tests/server/listenModePersonaSync.test.ts && node --experimental-strip-types tests/server/glassTranslate.test.ts",
    "glass:package": "npm run package --prefix glass-app",
    "glass:package:mac": "npm run package:mac --prefix glass-app",
    "glass:package:mac:arm64": "npm run package:mac:arm64 --prefix glass-app",
    "glass:package:mac:x64": "npm run package:mac:x64 --prefix glass-app",
    "glass:package:mac:universal": "npm run package:mac:universal --prefix glass-app",
    "glass:package:mac:release": "npm run package:mac:release --prefix glass-app",
    "glass:package:mac:signed": "npm run package:mac:signed --prefix glass-app",
    "glass:package:verify": "npm run package:verify --prefix glass-app",
    "glass:open:packaged": "npm run open:packaged --prefix glass-app",
    "glass:diagnose:permissions": "npm run diagnose:permissions --prefix glass-app",
    "glass:diagnose:permissions:packaged": "npm run diagnose:permissions:packaged --prefix glass-app",
    "glass:permissions:reset": "npm run permissions:reset --prefix glass-app"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "better-auth": "^1.6.16",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "pg": "^8.14.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.184.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
