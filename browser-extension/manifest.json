{
  "manifest_version": 3,
  "name": "IIVO Lens",
  "version": "1.1.8",
  "description": "Capture page context and send it to IIVO for decision analysis.",
  "permissions": ["activeTab", "scripting", "storage", "downloads"],
  "host_permissions": [
    "https://iivo.ai/*"
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "19": "assets/icon-19.png",
    "32": "assets/icon-32.png",
    "38": "assets/icon-38.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "IIVO Lens",
    "default_icon": {
      "16": "assets/icon-16.png",
      "19": "assets/icon-19.png",
      "32": "assets/icon-32.png",
      "38": "assets/icon-38.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
